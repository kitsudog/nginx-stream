BIND=1443:183.2.172.42:443
CONFIG_FILE=nginx.conf
DNS=8.8.8.8
FORWARD_1=www.abc.com:www.baidu.com
LISTEN_1=echo:httpbin.org/get?
LISTEN_1_CROSS_DOMAIN=true
LISTEN_2=https@www.test:cip.cc
LISTEN_2_EX=TRUE
LISTEN_2_TLS=TRUE
REDIRECT_1=baidu.games=https://www.baidu.com/
REDIRECT_2=mode2.baidu.games=https://www.baidu.com/
REDIRECT_2_MODE=no_uri
REDIRECT_3=mode3.baidu.games=https://www.baidu.com/
REDIRECT_3_MODE=hash
REPLACE_PATTERN=#www.baidu.com#www.google.com#
TIMEOUT=3600