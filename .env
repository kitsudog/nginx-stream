DNS=8.8.8.8
LISTEN_1=echo.com:httpbin.org/get?
LISTEN_1_CROSS_DOMAIN=true
LISTEN_1_CLIENT_SIZE=100m
LISTEN_1_CACHE=TRUE
LISTEN_1_CACHE_FORCE=TRUE
LISTEN_2=echo2.com:httpbin.org/get?
LISTEN_2_TLS_LISTEN_PORT=1443
LISTEN_2_TLS=TRUE
LISTEN_3=https@www.test.com:www.baidu.com
LISTEN_3_EX=TRUE
LISTEN_4=https@www.test2.com:www.baidu.com
LISTEN_4_EX=TRUE
LISTEN_4_TLS=TRUE
LISTEN_4_TLS_LISTEN_PORT=1443
LISTEN_5=https@local.bee.com:registry-1.docker.io:443@registry-1.docker.io
LISTEN_5_TLS_LISTEN_PORT=1443
LISTEN_5_CACHE=TRUE
LISTEN_5_CACHE_KEY=$proxy_host$uri
LISTEN_6=https@qcloud.com:www.baidu.com
LISTEN_6_GEO_WHITE=10.0.0.0/8
LISTEN_6_GEO_BLACK=127.0.0.1
LISTEN_6_GEO_REDIRECT=https://www.163.com
LISTEN_6_HEADER=env=123;env2=123
LISTEN_6_BAN_HEADER=env=black
FORWARD_1=www.test3.com:www.baidu.com
FORWARD_1_CLIENT_SIZE=100m
REDIRECT_1=baidu.games=https://www.baidu.com/
REDIRECT_2=mode2.baidu.games=https://www.baidu.com/
REDIRECT_2_MODE=no_uri
REDIRECT_3=mode3.baidu.games=https://www.baidu.com/
REDIRECT_3_MODE=hash
REPLACE_PATTERN=#.baidu.com#.google.com#
BIND_1=8080:www.baidu.com:443
BIND_2=udp@53:8.8.8.8:53
BIND_3=53:8.8.8.8:53
TIMEOUT=3600
PROXY_LISTEN_PORT=82
ENABLE_TUNNEL=TRUE
TUNNEL=rpc.ankr.com;www.baidu.com